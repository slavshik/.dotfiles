[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
[user]
	name = Alexander Slavschik
	email = slavshik@me.com
[interactive]
    diffFilter = delta --color-only
[core]
	autocrlf = input
	editor = nvim
    pager = delta
	excludesfile = ~/.gitignore
[delta]
    navigate = true
    light = true
    side-by-side = true
[merge]
    conflictstyle = diff3
[diff]
    colorMoved = default
    algorithm = histogram
[init]
    defaultBranch = main
[column]
    ui = auto
[branch]
    sort = -committerdate
[fetch]
    prune = true
[rebase]
    autoSquash = true
    autoStash = true
    updateRefs = true
[rerere]
    enabled = true
[commit]
    verbose = true
[push]
	autoSetupRemote = true
    useForceIfIncludes = true
